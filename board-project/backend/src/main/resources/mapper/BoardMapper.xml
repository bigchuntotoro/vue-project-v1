<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.board.mapper.BoardMapper">

    <resultMap id="boardResultMap" type="com.example.board.domain.Board">
        <id     property="id"          column="id"/>
        <result property="title"       column="title"/>
        <result property="writer"      column="writer"/>
        <result property="content"     column="content"/>
        <result property="viewCount"   column="view_count"/>
        <result property="createdDate" column="created_date"/>
        <result property="updatedDate" column="updated_date"/>
    </resultMap>

    <sql id="searchCondition">
        <if test="cond.keyword != null and cond.keyword != ''">
            <choose>
                <when test="cond.searchType == 'title'">
                    AND title LIKE CONCAT('%', #{cond.keyword}, '%')
                </when>
                <when test="cond.searchType == 'writer'">
                    AND writer LIKE CONCAT('%', #{cond.keyword}, '%')
                </when>
                <when test="cond.searchType == 'content'">
                    AND content LIKE CONCAT('%', #{cond.keyword}, '%')
                </when>
                <otherwise>
                    AND (title LIKE CONCAT('%', #{cond.keyword}, '%')
                         OR writer LIKE CONCAT('%', #{cond.keyword}, '%')
                         OR content LIKE CONCAT('%', #{cond.keyword}, '%'))
                </otherwise>
            </choose>
        </if>
    </sql>

    <select id="findAll" resultMap="boardResultMap">
        SELECT id, title, writer, content, view_count, created_date, updated_date
        FROM board
        WHERE 1 = 1
        <include refid="searchCondition"/>
        ORDER BY id DESC
        LIMIT #{cond.offset}, #{cond.size}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*)
        FROM board
        WHERE 1 = 1
        <include refid="searchCondition"/>
    </select>

    <select id="findById" resultMap="boardResultMap">
        SELECT id, title, writer, content, view_count, created_date, updated_date
        FROM board
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.example.board.domain.Board" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO board (title, writer, content, view_count, created_date, updated_date)
        VALUES (#{title}, #{writer}, #{content}, 0, NOW(), NOW())
    </insert>

    <update id="update" parameterType="com.example.board.domain.Board">
        UPDATE board
        SET title = #{title},
            writer = #{writer},
            content = #{content},
            updated_date = NOW()
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM board WHERE id = #{id}
    </delete>

    <update id="increaseViewCount">
        UPDATE board SET view_count = view_count + 1 WHERE id = #{id}
    </update>

</mapper>
