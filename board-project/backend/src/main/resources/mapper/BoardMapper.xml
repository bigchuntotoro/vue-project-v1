<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.board.mapper.BoardMapper">

    <resultMap id="boardResultMap" type="com.example.board.domain.Board">
        <id     property="id"          column="id"/>
        <result property="title"       column="title"/>
        <result property="writer"      column="writer"/>
        <result property="content"     column="content"/>
        <result property="viewCount"   column="view_count"/>
        <result property="createdDate" column="created_date"/>
        <result property="updatedDate" column="updated_date"/>
        <!-- 📎 [필수 추가] DB 컬럼명과 Java 도메인의 필드명을 연결해 줍니다 -->
        <result property="originFileName" column="origin_file_name" />
        <result property="storeFileName" column="store_file_name" />
        <result property="filePath" column="file_path" />
    </resultMap>

    <sql id="searchCondition">
        <if test="cond.keyword != null and cond.keyword != ''">
            <choose>
                <!-- DTO 필드명이 condition이므로 cond.condition으로 정확하게 비교합니다. -->
                <when test="cond.condition == 'title'">
                    AND title LIKE CONCAT('%', #{cond.keyword}, '%')
                </when>
                <when test="cond.condition == 'writer'">
                    AND writer LIKE CONCAT('%', #{cond.keyword}, '%')
                </when>
                <when test="cond.condition == 'content'">
                    AND content LIKE CONCAT('%', #{cond.keyword}, '%')
                </when>
                <!-- condition이 'all'이거나 비어있을 때는 전체 검색을 수행합니다. -->
                <otherwise>
                    AND (title LIKE CONCAT('%', #{cond.keyword}, '%')
                    OR writer LIKE CONCAT('%', #{cond.keyword}, '%')
                    OR content LIKE CONCAT('%', #{cond.keyword}, '%'))
                </otherwise>
            </choose>
        </if>
    </sql>

    <select id="findAll" resultMap="boardResultMap">
        SELECT id, title, writer, content, view_count, created_date, updated_date,
        origin_file_name,
        store_file_name,
        file_path
        FROM board
        WHERE 1 = 1
        <include refid="searchCondition"/>
        ORDER BY id DESC
        <!-- 💡 javaType과 jdbcType을 명시하여 강제로 정수 타입으로 파싱하게 만듭니다. -->
        LIMIT #{cond.offset, javaType=int, jdbcType=INTEGER}, #{cond.size, javaType=int, jdbcType=INTEGER}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*)
        FROM board
        WHERE 1 = 1
        <include refid="searchCondition"/>
    </select>

    <select id="findById" resultMap="boardResultMap">
        SELECT id, title, writer, content, view_count, created_date, updated_date,
        origin_file_name,
        store_file_name,
        file_path
        FROM board
        WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO board (
        title,
        writer,
        content,
        origin_file_name,
        store_file_name,
        file_path
        ) VALUES (
        #{title},
        #{writer},
        #{content},
        #{originFileName},
        #{storeFileName},
        #{filePath}
        )
    </insert>

    <update id="update" parameterType="com.example.board.domain.Board">
        UPDATE board
        SET title = #{title},
            writer = #{writer},
            content = #{content},
            origin_file_name = #{originFileName},
            store_file_name = #{storeFileName},
            file_path = #{filePath},
            updated_date = NOW()
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM board WHERE id = #{id}
    </delete>

    <update id="increaseViewCount">
        UPDATE board SET view_count = view_count + 1 WHERE id = #{id}
    </update>

</mapper>
